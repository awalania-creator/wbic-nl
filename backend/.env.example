PORT=3000
NODE_ENV=production

# ------------------------------------------------------------------
# Domain configuration
# ------------------------------------------------------------------
# Canonical production domain. Used by runbook tooling and for the
# default CORS/allowed-origin list.
PRIMARY_DOMAIN=wbic.nl

# Accept requests from the canonical domain, www, and the legacy
# staging host. Update once the migration to wbic.nl is stable and
# wbic.aiwbic.cloud is retired.
ALLOWED_ORIGINS=https://wbic.nl,https://www.wbic.nl,https://wbic.aiwbic.cloud

# ------------------------------------------------------------------
# SMTP (mail relay)
# ------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_FROM=info@wbic.nl

# ------------------------------------------------------------------
# Cloudflare Turnstile
# ------------------------------------------------------------------
# Server-side secret (verify endpoint). NEVER commit the real value.
CLOUDFLARE_TURNSTILE_SECRET=your_secret_here
# Public sitekey injected into contact.html at container start by
# docker-compose (see wbic-web.command). Leave as test key until the
# production sitekey (domain-bound to wbic.nl) is issued.
TURNSTILE_SITEKEY=1x00000000000000000000AA
